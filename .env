# CRM Network - Konfigurasi
# Salin file ini menjadi .env lalu isi nilainya

# InitData dari Telegram WebApp
INIT_DATA=user=%7B%22id%22%3A...GANTI_DENGAN_PUNYA_KAMU...%7D&auth_date=...&hash=...

# Interval claim mining dalam milidetik (default: 5 menit)
CLAIM_INTERVAL_MS=300000

# Interval energy boost dalam milidetik (default: 1 menit)
ENERGY_BOOST_INTERVAL_MS=60000

# Interval mining power boost claim dalam milidetik (default: 4 jam)
MINING_BOOST_INTERVAL_MS=14400000

# Interval cek & selesaikan task dalam milidetik (default: 10 menit)
TASK_INTERVAL_MS=600000

# Auto loop: true = terus berjalan, false = sekali saja
AUTO_LOOP=true

# Verbose mode: true = tampilkan response lengkap
VERBOSE=false
